#!/bin/sh
set -eu

PATH=/opt/bin:/opt/sbin:/bin:/sbin

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
# shellcheck disable=SC1091
. /opt/lib/wg-watchdog.sh

PID_FILE="${WG_PID_DIR}/wg-watchdog.pid"
trap 'rm -f "$PID_FILE"; exit 0' INT TERM EXIT

mkdir -p "$WG_PID_DIR"
echo $$ >"$PID_FILE"

while :; do
    load_config
    read_state

    if [ "${ENABLED:-1}" != "1" ]; then
        sleep "${POLL_INTERVAL:-30}"
        continue
    fi

    if ! status_line="$(read_interface_status "${WG_INTERFACE:-Wireguard0}")"; then
        sleep "${POLL_INTERVAL:-30}"
        continue
    fi

    rx="${status_line%%|*}"
    rest="${status_line#*|}"
    tx="${rest%%|*}"

    now="$(date +%s)"
    last_bounce="${LAST_BOUNCE:-0}"

    if [ "${rx:-0}" -eq "${RX_THRESHOLD:-0}" ] && [ "${tx:-0}" -gt "${TX_THRESHOLD:-1024}" ]; then
        if [ $((now - last_bounce)) -ge "${COOLDOWN:-300}" ]; then
            if bounce_interface "${WG_INTERFACE:-Wireguard0}"; then
                write_state "$rx" "$tx" "$now"
                sleep "${COOLDOWN:-300}"
                continue
            fi
        fi
    fi

    write_state "$rx" "$tx" "$last_bounce"
    sleep "${POLL_INTERVAL:-30}"
done

