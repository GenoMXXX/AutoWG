#!/bin/sh
set -eu

PATH=/opt/bin:/opt/sbin:/bin:/sbin

PID_DIR=/opt/var/run
CONF=/opt/etc/wg-watchdog.conf
SERVICE_PID="$PID_DIR/wg-watchdog-service.pid"

mkdir -p "$PID_DIR" /opt/var/log

is_running() {
    [ -r "$1" ] && kill -0 "$(cat "$1")" 2>/dev/null
}

stop_pidfile() {
    file="$1"
    is_running "$file" || { rm -f "$file"; return 0; }
    pid="$(cat "$file")"
    kill "$pid" 2>/dev/null || true
    rm -f "$file"
}

case "${1:-start}" in
    start)
        [ -f "$CONF" ] || cp /opt/etc/wg-watchdog.conf.sample "$CONF"
        if ! is_running "$SERVICE_PID"; then
            /opt/bin/wg-watchdog-service >/dev/null 2>&1 &
            echo $! >"$SERVICE_PID"
        fi
        ;;
    stop)
        stop_pidfile "$SERVICE_PID"
        stop_pidfile "$PID_DIR/wg-watchdog.pid"
        stop_pidfile "$PID_DIR/wg-watchdog-httpd.pid"
        ;;
    restart)
        "$0" stop
        sleep 1
        "$0" start
        ;;
    status)
        if is_running "$SERVICE_PID"; then
            echo "service running"
        else
            echo "service stopped"
        fi
        if [ -r "$PID_DIR/wg-watchdog.pid" ] && kill -0 "$(cat "$PID_DIR/wg-watchdog.pid")" 2>/dev/null; then
            echo "daemon running"
        else
            echo "daemon stopped"
        fi
        if [ -r "$PID_DIR/wg-watchdog-httpd.pid" ] && kill -0 "$(cat "$PID_DIR/wg-watchdog-httpd.pid")" 2>/dev/null; then
            echo "httpd running"
        else
            echo "httpd stopped"
        fi
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac

exit 0
